{"record_type": "definition", "term": "customs authorities", "term_normalized": "customs authorities", "definition": "the customs administrations of the Member States responsible for applying the customs legislation and any other authorities empowered under national law to apply certain customs legislation", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "1", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "customs legislation", "term_normalized": "customs legislation", "definition": "the body of legislation made up of all of the following:", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "2", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "the Code and the provisions supplementing or implementing it adopted at Union or national level", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "b", "text": "the Common Customs Tariff", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "c", "text": "the legislation setting up a Union system of reliefs from customs duty", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "d", "text": "international agreements containing customs provisions, insofar as they are applicable in the Union", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "e", "text": "Regulation (EU) 2022/2399 of the European Parliament and of the Council and the provisions supplementing or implementing it", "amendment": {"marker": "M4", "celex": "32022R2399", "action": "INSERTED"}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "customs controls", "term_normalized": "customs controls", "definition": "specific acts performed by the customs authorities in order to ensure compliance with the customs legislation and other legislation governing the entry, exit, transit, movement, storage and end-use of goods moved between the customs territory of the Union and countries or territories outside that territory, and the presence and movement within the customs territory of the Union of non-Union goods and goods placed under the end-use procedure", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "3", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "person", "term_normalized": "person", "definition": "a natural person, a legal person, and any association of persons which is not a legal person but which is recognised under Union or national law as having the capacity to perform legal acts", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "4", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "economic operator", "term_normalized": "economic operator", "definition": "a person who, in the course of his or her business, is involved in activities covered by the customs legislation", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "5", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "customs representative", "term_normalized": "customs representative", "definition": "any person appointed by another person to carry out the acts and formalities required under the customs legislation in his or her dealings with customs authorities", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "6", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "risk", "term_normalized": "risk", "definition": "the likelihood and the impact of an event occurring, with regard to the entry, exit, transit, movement or end-use of goods moved between the customs territory of the Union and countries or territories outside that territory and to the presence within the customs territory of the Union of non-Union goods, which would:", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "7", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "prevent the correct application of Union or national measures", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "b", "text": "compromise the financial interests of the Union and its Member States; or", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "c", "text": "pose a threat to the security and safety of the Union and its residents, to human, animal or plant health, to the environment or to consumers", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "customs formalities", "term_normalized": "customs formalities", "definition": "all the operations which must be carried out by a person and by the customs authorities in order to comply with the customs legislation", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "8", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "entry summary declaration", "term_normalized": "entry summary declaration", "definition": "the act whereby a person informs the customs authorities, in the prescribed form and manner and within a specific time-limit, that goods are to be brought into the customs territory of the Union", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "9", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "exit summary declaration", "term_normalized": "exit summary declaration", "definition": "the act whereby a person informs the customs authorities, in the prescribed form and manner and within a specific time-limit, that goods are to be taken out of the customs territory of the Union", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "10", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "temporary storage declaration", "term_normalized": "temporary storage declaration", "definition": "the act whereby a person indicates, in the prescribed form and manner, that goods are in temporary storage", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "11", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "customs declaration", "term_normalized": "customs declaration", "definition": "the act whereby a person indicates, in the prescribed form and manner, a wish to place goods under a given customs procedure, with an indication, where appropriate, of any specific arrangements to be applied", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "12", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "re-export declaration", "term_normalized": "re-export declaration", "definition": "the act whereby a person indicates, in the prescribed form and manner, a wish to take non-Union goods, with the exception of those under the free zone procedure or in temporary storage, out of the customs territory of the Union", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "13", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "re-export notification", "term_normalized": "re-export notification", "definition": "the act whereby a person indicates, in the prescribed form and manner, a wish to take non-Union goods which are under the free zone procedure or in temporary storage out of the customs territory of the Union", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "14", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "declarant", "term_normalized": "declarant", "definition": "the person lodging a customs declaration, a temporary storage declaration, an entry summary declaration, an exit summary declaration, a re-export declaration or a re-export notification in his or her own name or the person in whose name such a declaration or notification is lodged", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "15", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "customs procedure", "term_normalized": "customs procedure", "definition": "any of the following procedures under which goods may be placed in accordance with the Code:", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "16", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "release for free circulation", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "b", "text": "special procedures", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "c", "text": "export", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "temporary storage", "term_normalized": "temporary storage", "definition": "the situation of non-Union goods temporarily stored under customs supervision in the period between their presentation to customs and their placing under a customs procedure or re-export", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "17", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "customs debt", "term_normalized": "customs debt", "definition": "the obligation on a person to pay the amount of import or export duty which applies to specific goods under the customs legislation in force", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "18", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "debtor", "term_normalized": "debtor", "definition": "any person liable for a customs debt", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "19", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "import duty", "term_normalized": "import duty", "definition": "customs duty payable on the import of goods", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "20", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "export duty", "term_normalized": "export duty", "definition": "customs duty payable on the export of goods", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "21", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "customs status", "term_normalized": "customs status", "definition": "the status of goods as Union or non-Union goods", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "22", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "Union goods", "term_normalized": "union goods", "definition": "goods which fall into any of the following categories:", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "23", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "goods wholly obtained in the customs territory of the Union and not incorporating goods imported from countries or territories outside the customs territory of the Union", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "b", "text": "goods brought into the customs territory of the Union from countries or territories outside that territory and released for free circulation", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "c", "text": "goods obtained or produced in the customs territory of the Union, either solely from goods referred to in point (b) or from goods referred to in points (a) and (b)", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "non-Union goods", "term_normalized": "non-union goods", "definition": "goods other than those referred to in point 23 or which have lost their customs status as Union goods", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "24", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "risk management", "term_normalized": "risk management", "definition": "the systematic identification of risk, including through random checks, and the implementation of all measures necessary for limiting exposure to risk", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "25", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "release of goods", "term_normalized": "release of goods", "definition": "the act whereby the customs authorities make goods available for the purposes specified for the customs procedure under which they are placed", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "26", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "customs supervision", "term_normalized": "customs supervision", "definition": "action taken in general by the customs authorities with a view to ensuring that customs legislation and, where appropriate, other provisions applicable to goods subject to such action are observed", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "27", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "repayment", "term_normalized": "repayment", "definition": "the refunding of an amount of import or export duty that has been paid", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "28", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "remission", "term_normalized": "remission", "definition": "the waiving of the obligation to pay an amount of import or export duty which has not been paid", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "29", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "processed products", "term_normalized": "processed products", "definition": "goods placed under a processing procedure which have undergone processing operations", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "30", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "person established in the customs territory of the Union", "term_normalized": "person established in the customs territory of the union", "definition": ":", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "31", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "in the case of a natural person, any person who has his or her habitual residence in the customs territory of the Union", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "b", "text": "in the case of a legal person or an association of persons, any person having its registered office, central headquarters or a permanent business establishment in the customs territory of the Union", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "permanent business establishment", "term_normalized": "permanent business establishment", "definition": "a fixed place of business, where both the necessary human and technical resources are permanently present and through which a person's customs-related operations are wholly or partly carried out", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "32", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "presentation of goods to customs", "term_normalized": "presentation of goods to customs", "definition": "the notification to the customs authorities of the arrival of goods at the customs office or at any other place designated or approved by the customs authorities and the availability of those goods for customs controls", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "33", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "holder of the goods", "term_normalized": "holder of the goods", "definition": "the person who is the owner of the goods or who has a similar right of disposal over them or who has physical control of them", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "34", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "holder of the procedure", "term_normalized": "holder of the procedure", "definition": ":", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "35", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "the person who lodges the customs declaration, or on whose behalf that declaration is lodged; or", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "b", "text": "the person to whom the rights and obligations in respect of a customs procedure have been transferred", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "commercial policy measures", "term_normalized": "commercial policy measures", "definition": "non-tariff measures established, as part of the common commercial policy, in the form of Union provisions governing international trade in goods", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "36", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "processing operations", "term_normalized": "processing operations", "definition": "any of the following:", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "37", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "the working of goods, including erecting or assembling them or fitting them to other goods", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "b", "text": "the processing of goods", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "c", "text": "the destruction of goods", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "d", "text": "the repair of goods, including restoring them and putting them in order", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "e", "text": "the use of goods which are not to be found in the processed products, but which allow or facilitate the production of those products, even if they are entirely or partially used up in the process (production accessories)", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "rate of yield", "term_normalized": "rate of yield", "definition": "the quantity or percentage of processed products obtained from the processing of a given quantity of goods placed under a processing procedure", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "38", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "decision", "term_normalized": "decision", "definition": "any act by the customs authorities pertaining to the customs legislation giving a ruling on a particular case, and having legal effects on the person or persons concerned", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "39", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "carrier", "term_normalized": "carrier", "definition": ":", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "40", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "in the context of entry, the person who brings the goods, or who assumes responsibility for the carriage of the goods, into the customs territory of the Union. However,", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": [{"marker": "i", "text": "in the case of combined transportation, \"carrier\" means the person who operates the means of transport which, once brought into the customs territory of the Union, moves by itself as an active means of transport", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "ii", "text": "in the case of maritime or air traffic under a vessel-sharing or contracting arrangement, \"carrier\" means the person who concludes a contract and issues a bill of lading or air waybill for the actual carriage of the goods into the customs territory of the Union", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}]}, {"marker": "b", "text": "in the context of exit, the person who takes the goods, or who assumes responsibility for the carriage of the goods, out of the customs territory of the Union. However:", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": [{"marker": "i", "text": "in the case of combined transportation, where the active means of transport leaving the customs territory of the Union is only transporting another means of transport which, after the arrival of the active means of transport at its destination, will move by itself as an active means of transport, 'carrier' means the person who will operate the means of transport which will move by itself once the means of transport leaving the customs territory of the Union has arrived at its destination", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "ii", "text": "in the case of maritime or air traffic under a vessel-sharing or contracting arrangement, \"carrier\" means the person who concludes a contract, and issues a bill of lading or air waybill, for the actual carriage of the goods out of the customs territory of the Union", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}]}], "footnote_refs": []}
{"record_type": "definition", "term": "buying commission", "term_normalized": "buying commission", "definition": "a fee paid by an importer to an agent for representing him or her in the purchase of goods being valued.", "lang": "en", "approved": false, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "41", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "article_metadata", "lang": "en", "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "layout": "divlayout"}, "article_number": "5", "article_rubric": "Definitions", "context": {"article_number": "5", "article_rubric": "Definitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "definition_count": 41}
{"record_type": "footnote", "lang": "en", "source_ref": {"celex_id": "02013R0952-20221212", "footnote_id": "1"}, "marker": "1", "text": "This Regulation shall be binding in its entirety and directly applicable in all Member States."}
