{"record_type": "definition", "term": "dual-use items", "term_normalized": "dual-use items", "definition": "items, including software and technology, which can be used for both civil and military purposes, and includes items which can be used for the design, development, production or use of nuclear, chemical or biological weapons or their means of delivery, including all items which can be used for both non-explosive uses and assisting in any way in the manufacture of nuclear weapons or other nuclear explosive devices", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "1", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "export", "term_normalized": "export", "definition": ":", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "2", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "an export procedure within the meaning of Article 269 of the Union Customs Code", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "b", "text": "a re-export within the meaning of Article 270 of the Union Customs Code; a re-export also occurs if, during a transit through the customs territory of the Union according to point of this Article, an exit summary declaration has to be lodged because the final destination of the items has been changed", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "c", "text": "an outward processing procedure within the meaning of Article 259 of the Union Customs Code; or", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "d", "text": "transmission of software or technology by electronic media, including by fax, telephone, electronic mail or any other electronic means to a destination outside the customs territory of the Union; it includes making available in an electronic form such software and technology to natural or legal persons or to partnerships outside the customs territory of the Union; it also includes the oral transmission of technology when the technology is described over a voice transmission medium", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "exporter", "term_normalized": "exporter", "definition": ":", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "3", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "any natural or legal person or any partnership that, at the time when the export declaration or the re-export declaration or an exit summary declaration is accepted, holds the contract with the consignee in the third country and has the power to determine the sending of the items out of the customs territory of the Union; where no export contract has been concluded or if the holder of the contract does not act on its own behalf, exporter means the person who has the power to determine the sending of the items out of the customs territory of the Union; or", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "b", "text": "any natural or legal person or any partnership that decides to transmit software or technology by electronic media, including by fax, telephone, electronic mail or by any other electronic means to a destination outside the customs territory of the Union or to make available in an electronic form such software and technology to natural or legal persons or to partnerships outside the customs territory of the Union.", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "c", "text": "where point (a) or (b) is not applicable, any natural person carrying the dual-use items to be exported where these dual-use items are contained in the person’s personal baggage within the meaning of point (a) of Article 1 of Commission Delegated Regulation (EU) 2015/2446", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "export declaration", "term_normalized": "export declaration", "definition": "an act whereby any natural or legal person or any partnership indicates, in the prescribed form and manner, the wish to place dual-use items specified in point under an export procedure", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "4", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "re-export declaration", "term_normalized": "re-export declaration", "definition": "an act within the meaning of Article 5 of the Union Customs Code", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "5", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "exit summary declaration", "term_normalized": "exit summary declaration", "definition": "an act within the meaning of Article 5 of the Union Customs Code", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "6", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "brokering services", "term_normalized": "brokering services", "definition": ":", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "7", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "the negotiation or arrangement of transactions for the purchase, sale or supply of dual-use items from a third country to any other third country; or", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "b", "text": "the selling or buying of dual-use items that are located in third countries for their transfer to another third country.", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "broker", "term_normalized": "broker", "definition": "any natural or legal person or any partnership that provides brokering services from the customs territory of the Union into the territory of a third country", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "8", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "technical assistance", "term_normalized": "technical assistance", "definition": "any technical support related to repairs, development, manufacture, assembly, testing, maintenance, or any other technical service, and may take forms such as instruction, advice, training, transmission of working knowledge or skills or consulting services, including by electronic means as well as by telephone or any other verbal forms of assistance", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "9", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "provider of technical assistance", "term_normalized": "provider of technical assistance", "definition": ":", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "10", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "any natural or legal person or any partnership that provides technical assistance from the customs territory of the Union into the territory of a third country", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "b", "text": "any natural or legal person or any partnership resident or established in a Member State that provides technical assistance within the territory of a third country; or", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "c", "text": "any natural or legal person or any partnership resident or established in a Member State that provides technical assistance to a resident of a third country temporarily present in the customs territory of the Union", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "transit", "term_normalized": "transit", "definition": "a transport of non-Union dual-use items entering and passing through the customs territory of the Union with a destination outside the customs territory of the Union where those items:", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "11", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "are placed under an external transit procedure according to Article 226 of the Union Customs Code and only pass through the customs territory of the Union", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "b", "text": "are trans-shipped within, or directly re-exported from, a free zone", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "c", "text": "are in temporary storage and are directly re-exported from a temporary storage facility; or", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "d", "text": "were brought into the customs territory of the Union on the same vessel or aircraft that will take them out of that territory without unloading", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "individual export authorisation", "term_normalized": "individual export authorisation", "definition": "an authorisation granted to one specific exporter for one end-user or consignee in a third country and covering one or more dual-use items", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "12", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "global export authorisation", "term_normalized": "global export authorisation", "definition": "an authorisation granted to one specific exporter in respect of a type or category of dual-use items which may be valid for exports to one or more specified end-users and/or in one or more specified third countries", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "13", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "large project authorisation", "term_normalized": "large project authorisation", "definition": "an individual export authorisation or a global export authorisation granted to one specific exporter, in respect of a type or category of dual-use items which may be valid for exports to one or more specified end-users in one or more specified third countries for the purpose of a specified large-scale project", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "14", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "Union general export authorisation", "term_normalized": "union general export authorisation", "definition": "an export authorisation for exports to certain countries of destination that is available to all exporters who respect the conditions and requirements listed in Sections A to H of Annex II", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "15", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "national general export authorisation", "term_normalized": "national general export authorisation", "definition": "an export authorisation defined by national legislation in accordance with Article 12 and Section C of Annex III", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "16", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "customs territory of the Union", "term_normalized": "customs territory of the union", "definition": "the customs territory of the Union within the meaning of Article 4 of the Union Customs Code", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "17", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "non-Union dual-use items", "term_normalized": "non-union dual-use items", "definition": "items that have the status of non-Union goods within the meaning of Article 5 of the Union Customs Code", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "18", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "arms embargo", "term_normalized": "arms embargo", "definition": "an arms embargo imposed by a decision or a common position adopted by the Council or a decision of the Organisation for Security and Cooperation in Europe (OSCE) or an arms embargo imposed by a binding resolution of the Security Council of the United Nations", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "19", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "cyber-surveillance items", "term_normalized": "cyber-surveillance items", "definition": "dual-use items specially designed to enable the covert surveillance of natural persons by monitoring, extracting, collecting or analysing data from information and telecommunication systems", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "20", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "ICP", "term_normalized": "icp", "definition": "ongoing effective, appropriate and proportionate policies and procedures adopted by exporters to facilitate compliance with the provisions and objectives of this Regulation and with the terms and conditions of the authorisations implemented under this Regulation, including, inter alia, due diligence measures assessing risks related to the export of the items to end-users and end-uses", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "21", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "essentially identical transaction", "term_normalized": "essentially identical transaction", "definition": "a transaction concerning items with essentially identical parameters or technical characteristics and involving the same end-user or consignee as another transaction.", "lang": "en", "approved": true, "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "list_path": "22", "url": "https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:02021R0821-20210909#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "article_metadata", "lang": "en", "source_ref": {"celex_id": "02021R0821-20210909", "structural_path": "enc_1.cpt_I.art_2", "layout": "divlayout"}, "article_number": "2", "article_rubric": null, "context": {"article_number": "2", "article_rubric": null, "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "definition_count": 22}
{"record_type": "footnote", "lang": "en", "source_ref": {"celex_id": "02021R0821-20210909", "footnote_id": "1"}, "marker": "1", "text": "This Regulation shall be binding in its entirety and directly applicable in all Member States."}
{"record_type": "definition", "term": "dvejopo naudojimo prekės", "term_normalized": "dvejopo naudojimo prekės", "definition": "prekės, įskaitant programinę įrangą ir technologijas, kurios gali būti naudojamos ir civiliniams, ir kariniams tikslams, taip pat prekės, kurios gali būti naudojamos branduoliniams, cheminiams ar biologiniams ginklams ar jų siuntimo į taikinį sistemoms projektuoti, kurti, gaminti ar naudoti, įskaitant visas prekes, kurios gali būti ir neskirtos sprogdinti, ir gali kokiu nors būdu būti susijusios su branduolinių ginklų ar kitokių branduolinių sprogstamųjų įtaisų gamyba", "lang": "lt", "approved": true, "source_ref": {"celex_id": "02021R0821-20251115", "structural_path": "enc_1.cpt_I.art_2", "list_path": "1", "url": "https://eur-lex.europa.eu/legal-content/LT/TXT/HTML/?uri=CELEX:02021R0821-20251115#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": "OBJEKTAS IR TERMINŲ APIBRĖŽTYS", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "eksportas", "term_normalized": "eksportas", "definition": "", "lang": "lt", "approved": true, "source_ref": {"celex_id": "02021R0821-20251115", "structural_path": "enc_1.cpt_I.art_2", "list_path": "2", "url": "https://eur-lex.europa.eu/legal-content/LT/TXT/HTML/?uri=CELEX:02021R0821-20251115#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": "OBJEKTAS IR TERMINŲ APIBRĖŽTYS", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "eksporto procedūra, kaip apibrėžta Sąjungos muitinės kodekso 269 straipsnyje", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "b", "text": "reeksportas, kaip apibrėžta Sąjungos muitinės kodekso 270 straipsnyje; reeksportu taip pat laikomi tie atvejai, kai tranzito per Sąjungos muitų teritoriją metu pagal šio straipsnio 11 punktą turi būti pateikta išvežimo bendroji deklaracija, nes pasikeitė galutinė atitinkamų prekių paskirties vieta", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "c", "text": "laikinojo išvežimo perdirbti procedūra, nustatyta Sąjungos muitinės kodekso 259 straipsnyje, arba", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "d", "text": "programinės įrangos ar technologijų perdavimas elektroninėmis priemonėmis, tarp jų telefaksu, telefonu, elektroniniu paštu arba bet kokiomis kitomis elektroninėmis priemonėmis, į paskirties vietą už Sąjungos muitų teritorijos ribų; tai apima elektroninį tokios programinės įrangos ir technologijų tiekimą juridiniams ar fiziniams asmenims arba bendrijoms už Sąjungos muitų teritorijos ribų; tai taip pat apima technologijos perdavimą žodžiu, kai technologija apibūdinama balso perdavimo priemonėmis", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "eksportuotojas", "term_normalized": "eksportuotojas", "definition": "", "lang": "lt", "approved": true, "source_ref": {"celex_id": "02021R0821-20251115", "structural_path": "enc_1.cpt_I.art_2", "list_path": "3", "url": "https://eur-lex.europa.eu/legal-content/LT/TXT/HTML/?uri=CELEX:02021R0821-20251115#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": "OBJEKTAS IR TERMINŲ APIBRĖŽTYS", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "bet kuris fizinis ar juridinis asmuo arba bendrija, kuris (-i) priimant eksporto deklaraciją ar reeksporto deklaraciją ar išvežimo bendrąją deklaraciją yra pasirašęs sutartį su gavėju trečiojoje valstybėje ir turi įgaliojimą spręsti dėl prekių išsiuntimo iš Sąjungos muitų teritorijos; jei eksporto sutartis nesudaryta arba jei sutartį sudaręs asmuo veikia ne savo vardu, eksportuotoju laikomas asmuo, turintis įgaliojimą priimti sprendimą dėl prekių išsiuntimo iš Sąjungos muitų teritorijos; arba", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "b", "text": "bet kuris fizinis ar juridinis asmuo arba bendrija, kuris (-i) nusprendžia elektroninėmis priemonėmis, įskaitant faksą, telefoną, elektroninį paštą arba bet kokias kitas elektronines priemones, perduoti programinę įrangą ar technologijas į paskirties vietą už Sąjungos muitų teritorijos ribų arba tiekti elektronine forma tokią programinę įrangą ir technologiją fiziniams ar juridiniams asmenims arba bendrijoms už Sąjungos muitų teritorijos ribų.", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "c", "text": "jei a arba b punktas netaikomas, bet kuris fizinis asmuo, eksportuotinas dvejopo naudojimo prekes vežantis savo asmeniniame bagaže, kaip tai suprantama Komisijos deleguotojo reglamento (ES) 2015/2446 1 straipsnio 19 punkto a papunktyje", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "eksporto deklaracija", "term_normalized": "eksporto deklaracija", "definition": "veiksmas, kuriuo bet kuris fizinis ar juridinis asmuo arba bendrija nustatyta forma ir būdu išreiškia pageidavimą, kad dvejopo naudojimo prekėms, nurodytoms 1 punkte, būtų įforminta eksporto procedūra", "lang": "lt", "approved": true, "source_ref": {"celex_id": "02021R0821-20251115", "structural_path": "enc_1.cpt_I.art_2", "list_path": "4", "url": "https://eur-lex.europa.eu/legal-content/LT/TXT/HTML/?uri=CELEX:02021R0821-20251115#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": "OBJEKTAS IR TERMINŲ APIBRĖŽTYS", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
