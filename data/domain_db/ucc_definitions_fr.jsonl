{"record_type": "definition", "term": "droits à l'exportation", "term_normalized": "droits à l'exportation", "definition": "les droits de douane exigibles à l'exportation des marchandises", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "21", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "statut douanier", "term_normalized": "statut douanier", "definition": "le statut d'une marchandise comme marchandise de l'Union ou non Union", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "22", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "marchandises de l'Union", "term_normalized": "marchandises de l'union", "definition": "", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "23", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "les marchandises entièrement obtenues dans le territoire douanier de l'Union, sans apport de marchandises importées de pays ou territoires situés hors du territoire douanier de l'Union", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "b", "text": "les marchandises entrant dans le territoire douanier de l'Union en provenance de pays ou territoires situés hors de ce territoire et mises en libre pratique", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "c", "text": "les marchandises obtenues ou produites dans le territoire douanier de l'Union, soit à partir de marchandises visées au point b) exclusivement, soit à partir de marchandises visées aux points a) et b)", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "marchandises non Union", "term_normalized": "marchandises non union", "definition": "les marchandises autres que celles visées au point 23 ou qui ont perdu leur statut douanier de marchandises de l'Union", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "24", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "gestion du risque", "term_normalized": "gestion du risque", "definition": "la détection systématique d'un risque, y compris au moyen de contrôles inopinés, et la mise en œuvre de toutes les mesures nécessaires pour limiter l'exposition à ce risque", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "25", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "mainlevée d'une marchandise", "term_normalized": "mainlevée d'une marchandise", "definition": "l'acte par lequel les autorités douanières mettent à disposition une marchandise aux fins prévues par le régime douanier sous lequel elle est placée", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "26", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "surveillance douanière", "term_normalized": "surveillance douanière", "definition": "l'action générale menée par les autorités douanières en vue d'assurer le respect de la législation douanière et, le cas échéant, des autres dispositions applicables aux marchandises soumises à cette action", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "27", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "remboursement", "term_normalized": "remboursement", "definition": "la restitution d'un montant de droits ayant été acquitté à l'importation ou à l'exportation", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "28", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "remise", "term_normalized": "remise", "definition": "la dispense de payer un montant de droits à l'importation ou à l'exportation qui n'a pas été acquitté", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "29", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "produits transformés", "term_normalized": "produits transformés", "definition": "les marchandises placées sous un régime de transformation et ayant subi des opérations de transformation", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "30", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "personne établie sur le territoire douanier de l'Union", "term_normalized": "personne établie sur le territoire douanier de l'union", "definition": "", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "31", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "s'agissant d'une personne physique, toute personne qui y a sa résidence normale", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "b", "text": "s'agissant d'une personne morale ou d'une association de personnes, toute personne qui y a son siège légal, son administration centrale ou un établissement stable", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "établissement stable", "term_normalized": "établissement stable", "definition": "une installation fixe d'affaires disposant en permanence des ressources humaines et techniques nécessaires et par l'intermédiaire de laquelle les opérations douanières d'une personne sont effectuées en tout ou en partie", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "32", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "présentation en douane", "term_normalized": "présentation en douane", "definition": "la notification aux autorités douanières de l'arrivée des marchandises au bureau de douane ou en tout autre lieu désigné ou agréé par ces autorités douanières et de leur disponibilité aux fins des contrôles douaniers", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "33", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "détenteur des marchandises", "term_normalized": "détenteur des marchandises", "definition": "la personne qui a qualité de propriétaire des marchandises ou qui est titulaire d'un droit similaire d'en disposer ou encore qui exerce un contrôle physique sur ces marchandises", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "34", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "titulaire du régime", "term_normalized": "titulaire du régime", "definition": "", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "35", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "la personne qui dépose la déclaration en douane ou celle pour le compte de laquelle ladite déclaration est déposée; ou", "amendment": {"marker": "C4", "celex": "32013R0952R(15)", "action": "REPLACED"}, "sub_items": []}, {"marker": "b", "text": "la personne à qui les droits et les obligations relatifs à un régime douanier ont été transférés", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "mesures de politique commerciale", "term_normalized": "mesures de politique commerciale", "definition": "les mesures non tarifaires établies, dans le cadre de la politique commerciale commune, par les dispositions de l'Union applicables au commerce international de marchandises", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "36", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "opérations de transformation", "term_normalized": "opérations de transformation", "definition": "", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "37", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "l'ouvraison de marchandises, y compris leur montage, leur assemblage ou leur adaptation à d'autres marchandises", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "b", "text": "la transformation de marchandises", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "c", "text": "la destruction de marchandises", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "d", "text": "la réparation de marchandises, y compris leur remise en état et leur mise au point", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "e", "text": "l'utilisation de marchandises qui ne se retrouvent pas dans les produits transformés, mais qui permettent ou facilitent l'obtention de ces produits, même si elles disparaissent totalement ou partiellement au cours du processus (aides à la production)", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "taux de rendement", "term_normalized": "taux de rendement", "definition": "la quantité ou le pourcentage de produits transformés obtenus lors de la transformation d'une quantité déterminée de marchandises admises sous un régime de transformation", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "38", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "décision", "term_normalized": "décision", "definition": "tout acte concernant la législation douanière pris par une autorité douanière statuant sur un cas donné et qui a des effets de droit sur la ou les personnes concernées", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "39", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "transporteur", "term_normalized": "transporteur", "definition": "", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "40", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "dans le cadre de l'entrée de marchandises, la personne qui introduit les marchandises sur le territoire douanier de l'Union ou qui prend en charge leur transport sur ce territoire. Toutefois,", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": [{"marker": "i", "text": "en cas de transport combiné, on entend par \"transporteur\" la personne qui exploite le moyen de transport qui, après son entrée sur le territoire douanier de l'Union, circule de lui-même en tant que moyen de transport actif", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "ii", "text": "en cas de transport maritime ou aérien dans le cadre d'un accord de partage d'espace de navire/d'aéronef ou d'autres dispositions contractuelles, on entend par \"transporteur\" la personne qui conclut un contrat et qui émet un connaissement maritime ou une lettre de transport aérien pour le transport effectif des marchandises vers le territoire douanier de l'Union", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}]}, {"marker": "b", "text": "dans le cadre de la sortie de marchandises, la personne qui achemine les marchandises ou assume la responsabilité de leur transport hors du territoire douanier de l'Union. Toutefois:", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": [{"marker": "i", "text": "en cas de transport combiné, lorsque le moyen de transport actif quittant le territoire douanier de l'Union sert uniquement à transporter un autre moyen de transport qui, après l'arrivée à destination du moyen de transport actif, circulera de lui-même en tant que moyen de transport actif, on entend par \"transporteur\" la personne qui exploite le moyen de transport qui circulera de lui-même lorsque le moyen de transport quittant le territoire douanier de l'Union sera arrivé à destination", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "ii", "text": "en cas de transport maritime ou aérien dans le cadre d'un accord de partage d'espace de navire/d'aéronef ou d'autres dispositions contractuelles, on entend par \"transporteur\" la personne qui conclut un contrat et qui émet un connaissement maritime ou une lettre de transport aérien pour le transport effectif des marchandises hors du territoire douanier de l'Union", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}]}], "footnote_refs": []}
{"record_type": "definition", "term": "commission d'achats", "term_normalized": "commission d'achats", "definition": "la somme versée par un importateur à un agent pour le représenter en vue de l'achat des marchandises à évaluer.", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "41", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
