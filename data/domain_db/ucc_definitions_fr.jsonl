{"record_type": "definition", "term": "autorités douanières", "term_normalized": "autorités douanières", "definition": "les administrations douanières des États membres chargées de l'application de la législation douanière et toute autre autorité habilitée en droit national à appliquer certaines dispositions douanières", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "1", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "législation douanière", "term_normalized": "législation douanière", "definition": "", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "2", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "le code et les dispositions le complétant ou le mettant en œuvre adoptées au niveau de l'Union ou au niveau national", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "b", "text": "le tarif douanier commun", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "c", "text": "la législation établissant un régime de l'Union des franchises douanières", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "d", "text": "les accords internationaux comportant des dispositions douanières, dans la mesure où celles-ci sont applicables dans l'Union", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "e", "text": "Règlement (UE) 2022/2399 du Parlement européen et du Conseil ainsi que les dispositions le complétant ou le mettant en œuvre", "amendment": {"marker": "M4", "celex": "32022R2399", "action": "INSERTED"}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "contrôles douaniers", "term_normalized": "contrôles douaniers", "definition": "les actes spécifiques accomplis par les autorités douanières pour garantir la conformité avec la législation douanière et les autres dispositions régissant l'entrée, la sortie, le transit, la circulation, le stockage et la destination particulière de marchandises circulant entre le territoire douanier de l'Union et les pays ou les territoires situés en dehors de ce dernier, et la présence et la circulation sur le territoire douanier de l'Union de marchandises non Union et de marchandises placées sous le régime de la destination particulière", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "3", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "personne", "term_normalized": "personne", "definition": "une personne physique, une personne morale ou une association de personnes reconnue, en droit de l'Union ou en droit national, comme ayant la capacité d'accomplir des actes juridiques sans avoir le statut de personne morale", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "4", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "opérateur économique", "term_normalized": "opérateur économique", "definition": "une personne assurant, dans le cadre de ses activités professionnelles, des activités couvertes par la législation douanière", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "5", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "représentant en douane", "term_normalized": "représentant en douane", "definition": "toute personne désignée par une autre personne pour accomplir auprès des autorités douanières des actes ou des formalités prévus par la législation douanière", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "6", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "risque", "term_normalized": "risque", "definition": "", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "7", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "soit d'entraver l'application correcte de mesures de l'Union ou de mesures nationales", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "b", "text": "soit de porter préjudice aux intérêts financiers de l'Union et de ses États membres; ou", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "c", "text": "soit de constituer une menace pour la sécurité ou la sûreté de l'Union et de ses résidents, pour la santé des personnes, des animaux ou des végétaux, pour l'environnement ou les consommateurs", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "formalités douanières", "term_normalized": "formalités douanières", "definition": "l'ensemble des opérations que doivent exécuter une personne et les autorités douanières afin de se conformer à la législation douanière", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "8", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "déclaration sommaire d'entrée", "term_normalized": "déclaration sommaire d'entrée", "definition": "l'acte par lequel une personne informe les autorités douanières, dans les formes et selon les modalités prescrites, et dans un délai déterminé, que des marchandises vont entrer dans le territoire douanier de l'Union", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "9", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "déclaration sommaire de sortie", "term_normalized": "déclaration sommaire de sortie", "definition": "l'acte par lequel une personne informe les autorités douanières, dans les formes et selon les modalités prescrites, et dans un délai déterminé, que des marchandises vont sortir du territoire douanier de l'Union", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "10", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "déclaration de dépôt temporaire", "term_normalized": "déclaration de dépôt temporaire", "definition": "l'acte par lequel une personne indique, dans les formes et selon les modalités prescrites, que des marchandises sont en dépôt temporaire", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "11", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "déclaration en douane", "term_normalized": "déclaration en douane", "definition": "l'acte par lequel une personne manifeste, dans les formes et selon les modalités prescrites, la volonté d'assigner un régime douanier déterminé à une marchandise, en indiquant le cas échéant la procédure spécifique à appliquer", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "12", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "déclaration de réexportation", "term_normalized": "déclaration de réexportation", "definition": "l'acte par lequel une personne manifeste, dans les formes et selon les modalités prescrites, la volonté de sortir des marchandises non Union du territoire douanier de l'Union, à l'exception des marchandises se trouvant en zone franche ou en dépôt temporaire", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "13", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "notification de réexportation", "term_normalized": "notification de réexportation", "definition": "l'acte par lequel une personne manifeste, dans les formes et selon les modalités prescrites, la volonté de sortir du territoire douanier de l'Union des marchandises non Union qui se trouvent dans une zone franche ou en dépôt temporaire", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "14", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "déclarant", "term_normalized": "déclarant", "definition": "la personne qui dépose une déclaration en douane, une déclaration de dépôt temporaire, une déclaration sommaire d'entrée, une déclaration sommaire de sortie, une déclaration ou une notification de réexportation en son nom propre ou la personne au nom de laquelle une telle déclaration ou une telle notification est déposée", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "15", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "régime douanier", "term_normalized": "régime douanier", "definition": "", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "16", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "la mise en libre pratique", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "b", "text": "les régimes particuliers", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}, {"marker": "c", "text": "l'exportation", "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "dépôt temporaire", "term_normalized": "dépôt temporaire", "definition": "la situation dans laquelle se trouvent des marchandises non Union qui sont placées temporairement sous surveillance douanière entre leur présentation en douane et leur placement sous un régime douanier ou leur réexportation", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "17", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "dette douanière", "term_normalized": "dette douanière", "definition": "l'obligation incombant à une personne d'acquitter le montant des droits à l'importation ou à l'exportation applicables à des marchandises particulières en vertu de la législation douanière en vigueur", "lang": "fr", "approved": true, "source_ref": {"celex_id": "02013R0952-20221212", "structural_path": "enc_1.tis_I.tis_I.cpt_1.art_5", "list_path": "18", "url": "https://eur-lex.europa.eu/legal-content/FR/TXT/HTML/?uri=CELEX:02013R0952-20221212#art_5", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "32013R0952", "action": null}, "context": {"article_number": "5", "article_rubric": "Définitions", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
