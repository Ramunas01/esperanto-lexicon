{"record_type": "definition", "term": "tranzitas", "term_normalized": "tranzitas", "definition": "", "lang": "lt", "approved": false, "source_ref": {"celex_id": "02021R0821-20251115", "structural_path": "enc_1.cpt_I.art_2", "list_path": "11", "url": "https://eur-lex.europa.eu/legal-content/LT/TXT/HTML/?uri=CELEX:02021R0821-20251115#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": "OBJEKTAS IR TERMINŲ APIBRĖŽTYS", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "yra prekės, kurioms įforminta išorinio tranzito procedūra pagal Sąjungos muitinės kodekso 226 straipsnį ir kurios tik vežamos per Sąjungos muitų teritoriją", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "b", "text": "kurios yra perkraunamos laisvojoje zonoje arba tiesiogiai iš jos reeksportuojamos", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "c", "text": "kurios laikinai saugomos ir tiesiogiai reeksportuojamos iš laikinojo saugojimo sandėlio, arba", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "d", "text": "kurios į Sąjungos muitų teritoriją atgabentos ir neiškrovus bus iš tos teritorijos išgabentos tuo pačiu laivu arba orlaiviu", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}], "footnote_refs": []}
