{"record_type": "definition", "term": "išvežimo bendroji deklaracija", "term_normalized": "išvežimo bendroji deklaracija", "definition": "veiksmas, nurodytas Sąjungos muitinės kodekso 5 straipsnio 10 dalyje", "lang": "lt", "approved": false, "source_ref": {"celex_id": "02021R0821-20251115", "structural_path": "enc_1.cpt_I.art_2", "list_path": "6", "url": "https://eur-lex.europa.eu/legal-content/LT/TXT/HTML/?uri=CELEX:02021R0821-20251115#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": "OBJEKTAS IR TERMINŲ APIBRĖŽTYS", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "tarpininkavimo paslaugos", "term_normalized": "tarpininkavimo paslaugos", "definition": "", "lang": "lt", "approved": false, "source_ref": {"celex_id": "02021R0821-20251115", "structural_path": "enc_1.cpt_I.art_2", "list_path": "7", "url": "https://eur-lex.europa.eu/legal-content/LT/TXT/HTML/?uri=CELEX:02021R0821-20251115#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": "OBJEKTAS IR TERMINŲ APIBRĖŽTYS", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [{"marker": "a", "text": "derybos dėl dvejopo naudojimo prekių pirkimo, pardavimo arba tiekimo iš vienos trečiosios valstybės į bet kurią kitą trečiąją valstybę sandorių arba tokių sandorių organizavimas; arba", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}, {"marker": "b", "text": "dvejopo naudojimo prekių, esančių trečiosiose valstybėse, pardavimas arba pirkimas siekiant jas persiųsti į kitą trečiąją valstybę.", "amendment": {"marker": "B", "celex": "", "action": null}, "sub_items": []}], "footnote_refs": []}
{"record_type": "definition", "term": "tarpininkas", "term_normalized": "tarpininkas", "definition": "bet kuris fizinis ar juridinis asmuo arba bendrija, teikiantis (-i) tarpininkavimo paslaugas iš Sąjungos muitų teritorijos trečiosios valstybės teritorijoje", "lang": "lt", "approved": false, "source_ref": {"celex_id": "02021R0821-20251115", "structural_path": "enc_1.cpt_I.art_2", "list_path": "8", "url": "https://eur-lex.europa.eu/legal-content/LT/TXT/HTML/?uri=CELEX:02021R0821-20251115#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": "OBJEKTAS IR TERMINŲ APIBRĖŽTYS", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
{"record_type": "definition", "term": "techninė pagalba", "term_normalized": "techninė pagalba", "definition": "bet kokia techninė parama, susijusi su remontu, plėtra, gamyba, surinkimu, bandymu, technine priežiūra ar kitu techniniu aptarnavimu, teikiama instrukcijų, patarimų, mokymo, darbo žinių, įgūdžių perdavimo ar konsultacinių paslaugų forma, įskaitant pagalbą elektroninėmis priemonėmis, taip pat pagalbą žodžiu, teikiamą telefonu ar kitais būdais", "lang": "lt", "approved": false, "source_ref": {"celex_id": "02021R0821-20251115", "structural_path": "enc_1.cpt_I.art_2", "list_path": "9", "url": "https://eur-lex.europa.eu/legal-content/LT/TXT/HTML/?uri=CELEX:02021R0821-20251115#art_2", "layout": "divlayout"}, "amendment": {"marker": "B", "celex": "", "action": null}, "context": {"article_number": "2", "article_rubric": "OBJEKTAS IR TERMINŲ APIBRĖŽTYS", "title_label": null, "title_rubric": null, "chapter_label": null, "chapter_rubric": null, "section_label": null, "section_rubric": null}, "sub_items": [], "footnote_refs": []}
